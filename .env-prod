# Production Environment
APP_PROFILE=PROD
HTTP_PORT=8084
PUBLIC_INTERFACE=eth0

# Database
DB_HOST=prod-db
DB_PORT=5432
DB_USER=network_prod_user
DB_PASSWORD=network_prod_pass
